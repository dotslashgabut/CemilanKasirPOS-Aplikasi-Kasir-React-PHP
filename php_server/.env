# =============================================================================
# Cemilan KasirPOS - PHP Backend Environment Configuration
# =============================================================================
# Rename/copy this file to .env and fill in your actual values.
# This file is loaded automatically by config.php on every request.
# DO NOT commit your real .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_NAME=cemilankasirpos_php_v02
DB_USER=root
DB_PASS=

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# JWT secret key used to sign and verify authentication tokens.
# REQUIRED in production — replace with a long, random string (min 32 chars).
# Example: openssl rand -hex 32
JWT_SECRET=edit_your_jwt_secret_key_here_for_cemilankasirpos

# -----------------------------------------------------------------------------
# Debug / Error Reporting
# -----------------------------------------------------------------------------
# Set to true ONLY during local development. Never enable in production.
SHOW_DEBUG_ERRORS=false

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins (no trailing slash).
# Leave empty to fall back to the default behaviour defined in config.php.
# Example (production): ALLOWED_ORIGINS=https://yourdomain.com
# Example (multiple):   ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost
