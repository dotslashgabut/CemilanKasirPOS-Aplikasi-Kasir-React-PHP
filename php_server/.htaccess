<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Set RewriteBase for subfolder installation
    # This tells Apache that the backend is in /php_server/ subfolder
    RewriteBase /php_server/

    # Handle Authorization Header (for JWT/Bearer tokens)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Security: Redirect access to sensitive files (.env, hidden files), logs, and json to frontend
    # This prevents direct access but also avoids the 403 Forbidden blank page by redirecting to ../
    RewriteRule (^\.|.*\.log$|.*\.json$) ../ [R=301,L]

    # Redirect Trailing Slashes
    # Remove trailing slash from URLs (except directories)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ $1 [L,R=301]

    # Front Controller Pattern
    # Route all requests to index.php (except existing files/directories)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Security: Prevent directory listing
Options -Indexes

# Security Fallback: If mod_rewrite fails, ensure sensitive files are at least denied
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(log|json)$">
    Order allow,deny
    Deny from all
</FilesMatch>
